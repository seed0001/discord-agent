# Discord bot token — Discord Developer Portal > Bot > Token
DISCORD_TOKEN=

# Your Discord user ID — only this user can run server-management commands.
# (Discord: Settings > Advanced > Developer Mode, then right-click your profile > Copy User ID)
OWNER_ID=

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default AI model (changeable per server in the dashboard)
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Optional: GitHub token for repo analysis — raises the API rate limit from
# 60 to 5000 requests/hour. A fine-grained token with no extra permissions works.
GITHUB_TOKEN=

# Voice transcription (optional — enables voice-channel monitoring & wake words).
# Any OpenAI-compatible /audio/transcriptions endpoint works:
#   OpenAI:  TRANSCRIPTION_API_URL=https://api.openai.com/v1        TRANSCRIPTION_MODEL=whisper-1
#   Groq:    TRANSCRIPTION_API_URL=https://api.groq.com/openai/v1   TRANSCRIPTION_MODEL=whisper-large-v3
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_API_URL=https://api.openai.com/v1
TRANSCRIPTION_MODEL=whisper-1

# Fish Audio TTS for spoken voice replies (optional — falls back to edge-tts).
# Get a key at fish.audio. FISH_VOICE_ID is the voice model's reference id
# (pick a voice on fish.audio and copy the id from its page/URL).
# FISH_TTS_MODEL: "s2.1-pro-free" (default — free API tier, free-form
# [voice direction] tags), "s2.1-pro"/"s2-pro" (paid), or "s1" (fixed
# (emotion) tag vocabulary). The AI is prompted with the right tag style.
FISH_API_KEY=
FISH_TTS_MODEL=s2.1-pro-free
FISH_VOICE_ID=

# Password to log in to the web dashboard
DASHBOARD_PASSWORD=

# Random secret for signing dashboard sessions (any long random string).
# Also authenticates the voice listener sidecar to the bot's internal API,
# so it's REQUIRED for voice monitoring to work.
SECRET_KEY=

# Port for the voice listener sidecar's local control API (rarely needs changing)
SIDECAR_PORT=8091

# SQLite path. On Railway, attach a volume and point this inside it, e.g. /data/bot.db
DATABASE_PATH=data/bot.db

# Web port (Railway sets PORT automatically)
PORT=8000
